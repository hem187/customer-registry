# Copy this file to .env and fill in real values before running the server.

# Local MongoDB:   mongodb://127.0.0.1:27017/customer-care-registry
# MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster-url>/customer-care-registry
MONGO_URI=mongodb://127.0.0.1:27017/customer-care-registry

# Any long random string — used to sign JSON Web Tokens
JWT_SECRET=replace_this_with_a_long_random_string

# Port the API server listens on
PORT=5000

# Where the frontend runs, for CORS
CLIENT_ORIGIN=http://localhost:5173
